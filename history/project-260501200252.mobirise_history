                </div>\n                </div>\n            </div>\n            <div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n                <div class=\"item-wrapper\">\n                    <div class=\"item-img\">\n                        <a href=\"https://www.amazon.com/dp/B0F897VB35\"><img src=\"@PROJECT_PATH@/assets/images/a7-596x894.jpg\" alt=\"Packets, Firewalls & Sleepless Nights\" title data-slide-to=\"2\" data-bs-slide-to=\"2\"></a>\n                    </div>\n                </div>\n            </div>\n            <div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n                <div class=\"item-wrapper\">\n                    <div class=\"item-img\">\n                        <a href=\"https://www.amazon.com/dp/B0F89DTX2Q\" target=\"_blank\"><img src=\"@PROJECT_PATH@/assets/images/a9-596x894.jpg\" alt=\"The Corporate Survivor's Handbook\" title data-slide-to=\"3\" data-bs-slide-to=\"3\"></a>\n                    </div>\n                </div>\n            </div>\n            <div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n                <div class=\"item-wrapper\">\n                    <div class=\"item-img\">\n                        <a href=\"https://www.amazon.com/dp/B0FD8K6SDJ\" target=\"_blank\"><img src=\"@PROJECT_PATH@/assets/images/a42-596x894.jpg\" alt=\"The Indian Business Plan Blueprint\" title data-slide-to=\"4\" data-bs-slide-to=\"4\"></a>\n                    </div>\n                </div>\n            </div>\n            <div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n                <div class=\"item-wrapper\">\n                    <div class=\"item-img\">\n                        <a href=\"https://www.amazon.com/dp/B0FNKN41RX\" target=\"_blank\"><img src=\"@PROJECT_PATH@/assets/images/a69-596x894.jpg\" alt=\"Un-automatable\" title data-slide-to=\"5\" data-bs-slide-to=\"5\"></a>\n                    </div>\n                </div>